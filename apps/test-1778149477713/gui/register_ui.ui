   <string notr="true">QWidget#RegisterWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #f7fbfc, stop:1 #e6f6f5);
    font-family: &quot;Segoe UI&quot;;
}

QFrame#leftPanel {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0b3c5d, stop:1 #328cc1);
    border-radius: 20px;
}

QLabel#brandTitle {
    color: #ffffff;
    font-size: 28px;
    font-weight: 700;
}

QLabel#brandDesc {
    color: rgba(255,255,255,0.9);
    font-size: 14px;
    line-height: 1.6;
}

QFrame#cardPanel {
    background: #ffffff;
    border-radius: 20px;
    border: 1px solid #dbe8ee;
}

QLabel#lblRegisterTitle {
    color: #0b3c5d;
    font-size: 24px;
    font-weight: 700;
}

QLabel#lblRegisterUsername, QLabel#lblRegisterEmail, QLabel#lblRegisterPassword {
    color: #24465d;
    font-size: 13px;
    font-weight: 600;
}

QLineEdit {
    border: 1px solid #b7ccd8;
    border-radius: 10px;
    padding: 10px 12px;
    font-size: 13px;
    background: #fafdff;
    color: #123247;
    placeholder-text-color: #6c8798;
    selection-background-color: #328cc1;
    selection-color: #ffffff;
}

QLineEdit:focus {
    border: 1px solid #328cc1;
    background: #ffffff;
}

QPushButton#btnRegister {
    background: #0f7b78;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 14px;
    font-weight: 700;
}

QPushButton#btnRegister:hover {
    background: #0b6a68;
}

QPushButton#btnRegister:pressed {
    background: #095857;
}

QPushButton#btnGoLogin {
    background: transparent;
    color: #0b3c5d;
    border: none;
    font-size: 13px;
    font-weight: 600;
    text-align: left;
    padding: 6px 2px;
}

QPushButton#btnGoLogin:hover {
    color: #0f7b78;
}</string>
